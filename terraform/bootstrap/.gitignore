# ─── Terraform state (bootstrap creates the state backend;
#     its own local state is intentionally left on disk but not committed) ─────
*.tfstate
*.tfstate.*
*.tfstate.backup

# ─── Provider plugins / module cache ─────────────────────────────────────────
.terraform/

# ─── Plan files ───────────────────────────────────────────────────────────────
*.tfplan
*.tfplan.json

# ─── tfvars with real subscription ID ────────────────────────────────────────
terraform.tfvars
terraform.tfvars.json

# ─── Crash logs ───────────────────────────────────────────────────────────────
crash.log
crash.*.log
